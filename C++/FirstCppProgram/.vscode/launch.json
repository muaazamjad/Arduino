{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch", // The name that appears in the "Play" menu
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe", // Path to your artifact
            "args": [], // You can pass command line arguments here!
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false, // Change to true if you want a separate window
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\mingw64\\bin\\gdb.exe", // Path to the Debugger Engine
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Built with GCC 14.2.0" // MUST match the 'label' in tasks.json
        }
    ]
}